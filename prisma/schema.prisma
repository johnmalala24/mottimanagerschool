// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= AUTH & USER MANAGEMENT =============

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  DEPUTY_ADMIN
  ICT_ADMIN
  TEACHER
  CLASS_TEACHER
  STUDENT
  PARENT
  LIBRARIAN
  FINANCE
  RECEPTIONIST
  TRANSPORT_MANAGER
  HOSTEL_MANAGER
  ADMISSIONS_OFFICER
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  password          String?
  phone             String?
  address           String?
  role              UserRole         @default(STUDENT)
  active            Boolean          @default(true)
  schoolId          String?
  school            School?          @relation(fields: [schoolId], references: [id])
  
  // Relations
  teacher           Teacher?
  student           Student?
  parent            Parent?
  accounts          Account[]
  sessions          Session[]
  notifications     Notification[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([schoolId])
  @@index([email])
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============= SCHOOL & ORGANIZATION =============

enum SchoolType {
  PRIMARY
  SECONDARY
  MIXED
}

enum SubscriptionPlan {
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  SUSPENDED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TermStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum ExamStatus {
  DRAFT
  OPEN
  CLOSED
  PROCESSED
  PUBLISHED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
  LATE
}

enum InvoiceStatus {
  PAID
  PARTIAL
  OVERDUE
  PENDING
}

enum MpesaStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum MpesaType {
  STK_PUSH
  C2B
  MANUAL
}

model School {
  id                    String                @id @default(cuid())
  name                  String
  code                  String                @unique
  registrationId        String?               @unique
  schoolType            SchoolType            @default(PRIMARY)
  address               String?
  city                  String?
  state                 String?
  country               String?
  phone                 String?
  email                 String?
  website               String?
  logo                  String?
  principalName         String?
  establishedYear       Int?
  boardAffiliation      String?
  active                Boolean               @default(true)
  
  // Relations
  users                 User[]
  classes               Class[]
  subjects              Subject[]
  teachers              Teacher[]
  students              Student[]
  parents               Parent[]
  admissions            Admission[]
  feeStructures         FeeStructure[]
  feePayments           FeePayment[]
  feeInvoices           FeeInvoice[]
  attendance            Attendance[]
  grades                Grade[]
  timetables            Timetable[]
  libraryBooks          LibraryBook[]
  libraryIssuances      LibraryIssuance[]
  hostels               Hostel[]
  transports            Transport[]
  hostelAllocations     HostelAllocation[]
  transportAllocations  TransportAllocation[]
  notifications         Notification[]
  settings              SchoolSettings?
  subscription          SchoolSubscription?
  billingTransactions   BillingTransaction[]
  supportTickets        SupportTicket[]
  auditLogs             AuditLog[]
  academicYears         AcademicYear[]
  announcements         Announcement[]
  expenses              Expense[]
  mpesaTransactions     MpesaTransaction[]
  visitors              Visitor[]
  appointments          Appointment[]
  disciplineRecords     DisciplineRecord[]
  assignments           Assignment[]
  assignmentSubmissions AssignmentSubmission[]
  cbeAssessments        CbeAssessment[]
  cbeLearningAreas      CbeLearningArea[]
  learningMaterials     LearningMaterial[]
  exams                 Exam[]
  promotionBatches      PromotionBatch[]
  emailLogs             EmailLog[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model SchoolSettings {
  id                String   @id @default(cuid())
  schoolId          String   @unique
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  setupCompleted    Boolean  @default(false)
  cbeEnabled        Boolean  @default(false)
  smsEnabled        Boolean  @default(false)
  emailEnabled      Boolean  @default(true)
  whatsappEnabled   Boolean  @default(false)
  transportEnabled  Boolean  @default(false)
  libraryEnabled    Boolean  @default(true)
  hostelEnabled     Boolean  @default(false)
  payrollEnabled    Boolean  @default(false)
  themeColor        String   @default("#006b2c")
  accentColor       String   @default("#00628d")
  dashboardBgColor  String   @default("#f8f9ff")
  favicon           String?
  motto             String?
  disabledRoles     UserRole[] @default([])
  mpesaPaybill      String?
  academicStructure String   @default("CBC")
  termsPerYear      Int      @default(3)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SchoolSubscription {
  id            String             @id @default(cuid())
  schoolId      String             @unique
  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan   @default(STANDARD)
  status        SubscriptionStatus @default(PENDING)
  monthlyAmount Float              @default(0)
  renewalDate   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model BillingTransaction {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  amount        Float
  description   String?
  status        String   @default("COMPLETED")
  transactionId String?
  paymentDate   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([schoolId])
}

model SupportTicket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique
  schoolId     String
  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject      String
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([schoolId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actorName String?
  actorId   String?
  target    String?
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  icon      String?
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([createdAt])
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  terms     Term[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String
  startDate      DateTime
  endDate        DateTime
  status         TermStatus   @default(UPCOMING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([academicYearId])
}

model Announcement {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title          String
  message        String
  sendSms        Boolean  @default(false)
  sendEmail      Boolean  @default(false)
  emailsSent     Int      @default(0)
  recipientCount Int      @default(0)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([schoolId])
}

model Expense {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  category    String
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model MpesaTransaction {
  id            String      @id @default(cuid())
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId     String?
  student       Student?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  amount        Float
  phone         String?
  transactionId String?     @unique
  status        MpesaStatus @default(PENDING)
  type          MpesaType   @default(STK_PUSH)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

model FeeInvoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Float
  paidAmount    Float         @default(0)
  balance       Float
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime
  academicYear  String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

model Visitor {
  id        String    @id @default(cuid())
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  purpose   String?
  phone     String?
  checkIn   DateTime  @default(now())
  checkOut  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([schoolId])
}

model Appointment {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  visitorName String
  purpose     String?
  date        DateTime
  status      String   @default("Scheduled")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model DisciplineRecord {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId     String?
  description String
  action      String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([studentId])
}

model Assignment {
  id          String    @id @default(cuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId     String
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId   String?
  subject     Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacherId   String?
  teacher     Teacher?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  title       String
  description String?
  dueDate     DateTime?
  maxScore    Int       @default(100)
  status      String    @default("Open")
  submissions AssignmentSubmission[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
  @@index([classId])
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  schoolId     String
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content      String?          @db.Text
  fileUrl      String?
  score        Float?
  feedback     String?
  status       SubmissionStatus @default(SUBMITTED)
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([assignmentId, studentId])
  @@index([schoolId])
  @@index([studentId])
}

model Exam {
  id           String     @id @default(cuid())
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name         String
  classId      String
  class        Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  term         String
  academicYear String
  maxMarks     Int        @default(100)
  status       ExamStatus @default(DRAFT)
  subjectIds   String[]   @default([])
  publishedAt  DateTime?
  processedAt  DateTime?
  createdById  String?
  grades       Grade[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([schoolId])
  @@index([classId])
  @@index([status])
}

model CbeLearningArea {
  id        String      @id @default(cuid())
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  code      String
  gradeLevel String?
  strands   CbeStrand[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([schoolId, code])
  @@index([schoolId])
}

model CbeStrand {
  id             String          @id @default(cuid())
  learningAreaId String
  learningArea   CbeLearningArea @relation(fields: [learningAreaId], references: [id], onDelete: Cascade)
  name           String
  code           String
  competencies   CbeCompetency[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([learningAreaId, code])
}

model CbeCompetency {
  id        String    @id @default(cuid())
  strandId  String
  strand    CbeStrand @relation(fields: [strandId], references: [id], onDelete: Cascade)
  name      String
  code      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([strandId, code])
}

model PromotionBatch {
  id              String   @id @default(cuid())
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fromAcademicYear String
  toAcademicYear  String
  promotedCount   Int      @default(0)
  repeatedCount   Int      @default(0)
  graduatedCount  Int      @default(0)
  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())

  @@index([schoolId])
}

model EmailLog {
  id        String   @id @default(cuid())
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  to        String
  subject   String
  type      String
  status    String   @default("SENT")
  error     String?
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([createdAt])
}

model CbeAssessment {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  learningArea String
  level        String
  term         String
  academicYear String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
  @@index([studentId])
}

model LearningMaterial {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId   String?
  class     Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  title     String
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

// ============= ACADEMIC STRUCTURE =============

model Class {
  id              String            @id @default(cuid())
  schoolId        String
  school          School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String            // e.g., "Class 10-A"
  section         String            // e.g., "A", "B", "C"
  academicYear    String            // e.g., "2024-2025"
  classTeacherId  String?
  classTeacher    Teacher?          @relation(fields: [classTeacherId], references: [id])
  capacity        Int               @default(50)
  
  // Relations
  students        Student[]
  subjects        Subject[]
  attendance      Attendance[]
  grades          Grade[]
  timetables      Timetable[]
  assignments     Assignment[]
  learningMaterials LearningMaterial[]
  exams           Exam[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([schoolId, name, academicYear])
  @@index([schoolId])
  @@index([classTeacherId])
}

model Subject {
  id              String            @id @default(cuid())
  schoolId        String
  school          School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String
  code            String
  description     String?
  maxMarks        Int               @default(100)
  
  // Relations
  classes         Class[]
  teachers        Teacher[]
  grades          Grade[]
  timetables      Timetable[]
  assignments     Assignment[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([schoolId, code])
  @@index([schoolId])
}

// ============= PEOPLE MANAGEMENT =============

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  GRADUATED
  DROPPED_OUT
}

model Student {
  id                    String                @id @default(cuid())
  schoolId              String
  school                School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId                String                @unique
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  registrationNumber    String                @unique
  classId               String
  class                 Class                 @relation(fields: [classId], references: [id])
  dateOfBirth           DateTime?
  gender                String?
  guardianName          String?
  guardianPhone         String?
  admissionNumber       String?
  admissionDate         DateTime?
  status                StudentStatus         @default(ACTIVE)
  
  // Relations
  parentId              String?
  parent                Parent?               @relation(fields: [parentId], references: [id])
  attendance            Attendance[]
  grades                Grade[]
  feePayments           FeePayment[]
  hostelAllocations     HostelAllocation[]
  transportAllocations  TransportAllocation[]
  feeInvoices           FeeInvoice[]
  mpesaTransactions     MpesaTransaction[]
  disciplineRecords     DisciplineRecord[]
  cbeAssessments        CbeAssessment[]
  libraryIssuances      LibraryIssuance[]
  assignmentSubmissions AssignmentSubmission[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([schoolId])
  @@index([classId])
  @@index([userId])
  @@index([parentId])
}

model Teacher {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId        String            @unique
  isClassTeacher    Boolean           @default(false)
  dateOfBirth       DateTime?
  gender            String?
  qualification     String?
  experience        Int?
  joinDate          DateTime
  dateOfLeaving     DateTime?
  subjectId         String?
  subject           Subject?          @relation(fields: [subjectId], references: [id])
  
  // Relations
  classesTeaching   Class[]
  attendance        Attendance[]
  timetables        Timetable[]
  assignments       Assignment[]
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([userId])
  @@index([subjectId])
}

model Parent {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  relationship      String?           // "Father", "Mother", "Guardian"
  occupation        String?
  annualIncome      Int?
  
  // Relations
  students          Student[]
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([userId])
}

// ============= ADMISSIONS =============

enum AdmissionStatus {
  APPLIED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
  ADMITTED
}

model Admission {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  applicationNumber String            @unique
  studentName       String
  dateOfBirth       DateTime
  gender            String
  fatherName        String
  motherName        String?
  guardianName      String?
  contactNumber     String
  email             String
  address           String
  applyingForClass  String
  previousSchool    String?
  status            AdmissionStatus   @default(APPLIED)
  remarks           String?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([status])
}

// ============= ATTENDANCE =============

model Attendance {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId           String
  class             Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherId         String?
  teacher           Teacher?          @relation(fields: [teacherId], references: [id])
  date              DateTime
  status            String            // "Present", "Absent", "Leave", "Late"
  remarks           String?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([classId, studentId, date])
  @@index([schoolId])
  @@index([classId])
  @@index([studentId])
  @@index([teacherId])
}

// ============= GRADES & ASSESSMENT =============

model Grade {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId           String
  class             Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId         String
  subject           Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  examId            String?
  exam              Exam?             @relation(fields: [examId], references: [id], onDelete: SetNull)
  examName          String
  marks             Float?
  gradePoint        String?
  position          Int?
  teacherComment    String?
  term              String
  academicYear      String
  isPublished       Boolean           @default(false)
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([schoolId, studentId, subjectId, examName, academicYear])
  @@index([schoolId])
  @@index([classId])
  @@index([studentId])
  @@index([subjectId])
  @@index([examId])
}

// ============= TIMETABLE =============

model Timetable {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId           String
  class             Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId         String
  subject           Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId         String
  teacher           Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek         String            // "Monday", "Tuesday", etc.
  startTime         String            // "09:00"
  endTime           String            // "10:00"
  room              String?
  academicYear      String
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([schoolId, classId, subjectId, teacherId, dayOfWeek, startTime, academicYear])
  @@index([schoolId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
}

// ============= FINANCE & FEES =============

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  DEFAULTED
}

model FeeStructure {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  className         String
  academicYear      String
  tuitionFee        Float
  developmentFee    Float             @default(0)
  libraryFee        Float             @default(0)
  sportsFee         Float             @default(0)
  transportFee      Float             @default(0)
  computerFee       Float             @default(0)
  otherFee          Float             @default(0)
  totalFee          Float
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([schoolId, className, academicYear])
  @@index([schoolId])
}

model FeePayment {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount            Float
  paymentDate       DateTime
  dueDate           DateTime
  status            PaymentStatus     @default(PENDING)
  mode              String            // "Cash", "Cheque", "Online", etc.
  transactionId     String?
  remarks           String?
  academicYear      String
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

// ============= LIBRARY =============

enum BookStatus {
  AVAILABLE
  ISSUED
  RESERVED
  DAMAGED
  LOST
}

model LibraryBook {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title             String
  author            String
  isbn              String?           @unique
  publishedYear     Int?
  category          String
  quantity          Int
  availableQuantity Int
  location          String?
  status            BookStatus        @default(AVAILABLE)
  
  // Relations
  issuances         LibraryIssuance[]
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([status])
}

model LibraryIssuance {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  bookId            String
  book              LibraryBook       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  studentId         String?
  student           Student?          @relation(fields: [studentId], references: [id], onDelete: SetNull)
  dueDate           DateTime
  returnDate        DateTime?
  fine              Float             @default(0)
  status            String            // "Issued", "Returned", "Overdue"
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([bookId])
  @@index([studentId])
}

// ============= HOSTEL =============

model Hostel {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name              String
  type              String            // "Boys", "Girls"
  address           String?
  capacity          Int
  warden            String?
  
  // Relations
  allocations       HostelAllocation[]
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model HostelAllocation {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  hostelId          String
  hostel            Hostel            @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  roomNumber        String
  bedNumber         String
  allocationDate    DateTime
  releaseDate       DateTime?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([hostelId])
}

// ============= TRANSPORT =============

model Transport {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  routeName         String
  routeNumber       String
  vehicleNumber     String
  driverName        String
  driverPhone       String?
  capacity          Int
  monthlyFee        Float
  
  // Relations
  allocations       TransportAllocation[]
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([schoolId, routeNumber, vehicleNumber])
  @@index([schoolId])
}

model TransportAllocation {
  id                String            @id @default(cuid())
  schoolId          String
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transportId       String
  transport         Transport         @relation(fields: [transportId], references: [id], onDelete: Cascade)
  stopPoint         String
  allocationDate    DateTime
  releaseDate       DateTime?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([transportId])
}

// ============= NOTIFICATIONS =============

model Notification {
  id                String            @id @default(cuid())
  schoolId          String?
  school            School?           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  message           String
  type              String            // "Info", "Warning", "Error", "Success"
  read              Boolean           @default(false)
  readAt            DateTime?
  actionUrl         String?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([schoolId])
  @@index([userId])
  @@index([read])
}
